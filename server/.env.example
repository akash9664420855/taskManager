PORT=4000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/taskmanager
JWT_ACCESS_SECRET=replace_me_with_a_long_random_string_at_least_32_chars
JWT_REFRESH_SECRET=replace_me_with_a_different_long_random_string_at_least_32_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
CLIENT_ORIGIN=http://localhost:5173
COOKIE_SECURE=false
# `none` is required for cross-domain cookies and forces COOKIE_SECURE=true behaviour in browsers
COOKIE_SAMESITE=lax
